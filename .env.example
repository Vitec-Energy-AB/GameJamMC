# Server port (default: 3000)
PORT=3000

# Allowed CORS origin for Socket.IO (use specific domain in production)
# Examples: https://mygame.example.com  or  *
CORS_ORIGIN=*

# Path to the leaderboard JSON data file (defaults to ./data/leaderboard.json)
# LEADERBOARD_FILE=/absolute/path/to/leaderboard.json
